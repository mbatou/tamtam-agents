# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_SOCIAL=
SLACK_CHANNEL_GROWTH=
SLACK_CHANNEL_COO=
# Optional but required for Session 4 features (team standup,
# inter-agent reactions, random moments, Friday wrap-up, Georges
# check-in detector). Channel ID of #tamtam-team. When unset, those
# functions log a skip and exit cleanly — existing flows keep working.
SLACK_CHANNEL_TEAM=
# Optional. When set, COO escalations DM Georges directly instead of
# @channel-mentioning in #tamtam-coo, AND the Georges check-in detector
# in /api/slack/events listens for casual messages from this user id
# in #tamtam-team. Find the user id in Slack:
# Profile -> ⋮ -> Copy member ID.
SLACK_GEORGES_USER_ID=

