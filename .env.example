SLACK_APPROVALS_CHANNEL=C0123456789      # channel where approvals are sent
SLACK_COO_CHANNEL=C0123456789            # #tamtam-coo
SLACK_GEORGES_USER_ID=U0123456789        # for @mentions when escalating

# ─── Resend ───────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Georges Mbatou <georges@tamtam.africa>

# ─── Inngest ──────────────────────────────────────────────────────────────
