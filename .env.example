# ─── Slack — three apps, one per agent identity ─────────────────────────
# Each agent has their own Slack app, bot token, signing secret, and
# Slack user. There is no `chat.write.customize` persona override
# anywhere — when Awa speaks, Awa's app posts via Awa's token.
#
# Required scopes per app (set in each Slack app dashboard):
#   chat:write, chat:write.public, app_mentions:read,
#   channels:history, im:write, im:history,
#   users.profile:write, users:read
#
# Required event subscriptions per app:
#   app_mention, message.channels, member_joined_channel
#
# Awa — Social Media Lead
SLACK_BOT_TOKEN_AWA=
SLACK_SIGNING_SECRET_AWA=
SLACK_APP_ID_AWA=

# Kofi — Growth & Sales Lead
SLACK_BOT_TOKEN_KOFI=
SLACK_SIGNING_SECRET_KOFI=
SLACK_APP_ID_KOFI=

# Rama — COO
SLACK_BOT_TOKEN_RAMA=
SLACK_SIGNING_SECRET_RAMA=
SLACK_APP_ID_RAMA=

# Channel ids (C0XXXXXXXXX format — never names)
SLACK_CHANNEL_SOCIAL=
SLACK_CHANNEL_GROWTH=
SLACK_CHANNEL_COO=

# Optional. The shared inter-agent channel (#tamtam-team).
# When unset, team-life Inngest functions log a skip and exit cleanly.
SLACK_CHANNEL_TEAM=

# Optional. Used by Rama's `dm_georges` tool (open real DM via
# conversations.open) and the Georges check-in detector
# (filter which user_id to listen for in #tamtam-team).
SLACK_GEORGES_USER_ID=

# ─── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: defaults to "tamtam-social"
SUPABASE_STORAGE_BUCKET=

# ─── AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=

# ─── Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Job queue ──────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── LinkedIn ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional, only required when publish_post wires the real API.
LINKEDIN_PAGE_ID=
# Optional. OAuth bearer for LinkedIn messaging / connections.
# Until partnership-tier API access lands, lib/linkedin.ts uses a
# "queued for manual send" fallback regardless of this token's
# presence. See lib/linkedin.ts for the swap-in path.
LINKEDIN_ACCESS_TOKEN=

# ─── Email-reply webhook (Kofi response monitor) ────────────────────────
# Optional. Shared HMAC-SHA256 secret used to verify inbound webhook
# payloads from whichever inbound-email service you wire (Resend
# Inbound, SendGrid Inbound Parse, Mailgun, IMAP-bridge). When unset,
# /api/webhooks/email-reply rejects all requests with 401.
RESEND_WEBHOOK_SECRET=

# ─── Meta / Instagram (parked) ──────────────────────────────────────────
# META_APP_ID=
# META_APP_SECRET=
# INSTAGRAM_ACCOUNT_ID=

# ─── App ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development
